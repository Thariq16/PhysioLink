# ============================================================
# PhysioLink – .gitignore
# Next.js 16 · TypeScript · Tailwind CSS 4
# ============================================================

# ---- Dependencies ------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js build output ----------------------------------
.next/
out/
build/

# ---- Test & coverage ---------------------------------------
coverage/
.nyc_output/

# ---- Environment variables ---------------------------------
# Never commit secrets. Use your host's env-var UI instead.
.env
.env.*
!.env.example

# ---- Logs --------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- OS / editor artefacts ---------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.pem

# ---- IDEs & editors ----------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- TypeScript --------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ---- Deployment platforms ----------------------------------
.vercel/

# ---- Project reference documents (not for production) -----
physiolink_prd.html
physiolink_brand_ui.html

# ---- Misc --------------------------------------------------
*.tgz
*.zip
